FROM registry.access.redhat.com/ubi9/python-314@sha256:1db6cc7b73899a00d1e08a3b5663a9692ce11f2b256f0c71a877a496cf9e730d AS base

COPY LICENSE /licenses/

ENV \
    # unbuffered output for easier logging
    PYTHONUNBUFFERED=1 \
    # use venv from ubi image
    UV_PROJECT_ENVIRONMENT=$APP_ROOT \
    # disable uv cache. it doesn't make sense in a container
    UV_NO_CACHE=true \
    USER=1001

USER root
# install the kerberos bindings to support Kerberos if the user runs the CLI via docker
RUN dnf install -y make krb5-libs krb5-workstation && dnf clean all && rm -rf /var/cache/yum
USER ${USER}

FROM base AS builder
COPY --from=ghcr.io/astral-sh/uv:0.11.23@sha256:d0a0a753ab981624b49c97abc98821c1c09f4ca69d1ef5cee69c501be3d88479 /uv /bin/uv

USER root
# install the build dependencies
RUN dnf install -y make gcc krb5-devel
USER ${USER}

COPY pyproject.toml uv.lock ./
# Unused packages but defined in global pyproject.toml.
COPY packages/automated_actions/pyproject.toml ./packages/automated_actions
COPY packages/integration_tests/pyproject.toml ./packages/integration_tests
COPY packages/automated_actions_utils ./packages/automated_actions_utils
# automated_actions_client is a dependency of automated_actions_cli
COPY packages/automated_actions_client ./packages/automated_actions_client
COPY packages/automated_actions_cli/README.md ./packages/automated_actions_cli/
COPY packages/automated_actions_cli/pyproject.toml ./packages/automated_actions_cli/
# install just the dependencies
RUN cd ./packages/automated_actions_cli/ && uv sync --frozen --no-install-project --no-group dev

COPY packages/automated_actions_cli/Makefile ./packages/automated_actions_cli/
COPY packages/automated_actions_cli/tests ./packages/automated_actions_cli/tests
COPY packages/automated_actions_cli/automated_actions_cli ./packages/automated_actions_cli/automated_actions_cli
RUN cd ./packages/automated_actions_cli/ && uv sync --frozen --no-group dev

#
# Test image
#
FROM base AS test
COPY --from=ghcr.io/astral-sh/uv:0.11.23@sha256:d0a0a753ab981624b49c97abc98821c1c09f4ca69d1ef5cee69c501be3d88479 /uv /bin/uv

COPY --from=builder --chown=${USER}:root $APP_ROOT $APP_ROOT

RUN cd ./packages/automated_actions_cli/ && uv sync --frozen
RUN make -C packages/automated_actions_cli test

#
# PyPI publish image
#
FROM test AS pypi
# Secrets are owned by root and are not readable by others :(
USER root
RUN --mount=type=secret,id=app-sre-pypi-credentials/token UV_PUBLISH_TOKEN=$(cat /run/secrets/app-sre-pypi-credentials/token) make -C packages/automated_actions_cli pypi
USER 1001
